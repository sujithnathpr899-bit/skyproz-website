NODE_ENV=development
PORT=8787
HOST=127.0.0.1
DATABASE_PATH=./contract-finder/data/contract-finder.db
COMPANY_SITE_DIR=./outputs
APP_ORIGIN=http://127.0.0.1:8787
SESSION_SECRET=replace-with-at-least-32-random-characters
COOKIE_SECURE=false

# Optional AI provider. The endpoint must accept OpenAI-compatible chat completions.
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=
AI_MODEL=

# Optional email delivery through Resend.
RESEND_API_KEY=
EMAIL_FROM=Skyproz Contract Finder <alerts@skyproz.in>

# Optional WhatsApp Cloud API.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v23.0

# Optional Telegram bot notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI procurement bot scheduler and matching controls.
BOT_SCHEDULER_ENABLED=false
BOT_SCHEDULER_INTERVAL_MINUTES=60
BOT_IMPORT_CONCURRENCY=4
BOT_RETRY_ATTEMPTS=2
BOT_HIGH_SCORE_THRESHOLD=75
BOT_HIGH_VALUE_BUDGET=100000
BOT_COUNTRIES=

# Used by external schedulers to authorize job runs.
CRON_SECRET=replace-with-a-random-cron-secret
